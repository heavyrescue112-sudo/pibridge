#!/bin/bash

# --- SELF-UPDATER ---
if [ "$1" == "update" ]; then
    echo "Checking GitHub for the latest .deb release..."
    URL=$(curl -s https://api.github.com/repos/heavyrescue112-sudo/PiBridge/releases/latest \
          | grep "browser_download_url" | grep ".deb" | head -n 1 | sed -E 's/.*"([^"]+)".*/\1/')
    if [ -z "$URL" ]; then echo "Error: No .deb found."; exit 1; fi
    curl -L "$URL" -o /tmp/pibridge.deb
    sudo apt install --reinstall -y /tmp/pibridge.deb
    rm /tmp/pibridge.deb
    exit 0
fi

# --- BRIDGE CONFIG ---
WIFI_IFACE="wlan0"
ETH_IFACE="eth0"
ETH_IP="192.168.68.250/22" 

# 1. Kill old services to avoid conflicts
systemctl stop dhcp-helper 2>/dev/null
killall parprouted 2>/dev/null 

# 2. Reset the Ethernet Port
nmcli device set "$ETH_IFACE" managed no 2>/dev/null
ip link set "$ETH_IFACE" down
ip addr flush dev "$ETH_IFACE"
ip link set "$ETH_IFACE" up
ip addr add "$ETH_IP" dev "$ETH_IFACE"

# 3. UNLOCK THE KERNEL (The "Secret Sauce")
# This allows the Pi to answer ARP requests on behalf of your desktop
echo 1 > /proc/sys/net/ipv4/conf/all/proxy_arp
echo 1 > /proc/sys/net/ipv4/conf/$WIFI_IFACE/proxy_arp
echo 1 > /proc/sys/net/ipv4/conf/$ETH_IFACE/proxy_arp
sysctl -w net.ipv4.ip_forward=1 > /dev/null

# 4. Open the "Ears" (Promiscuous Mode)
# This lets the Pi accept packets not addressed to its own MAC
ip link set "$WIFI_IFACE" promisc on
ip link set "$ETH_IFACE" promisc on

# 5. Start the Bridge Engine
parprouted "$WIFI_IFACE" "$ETH_IFACE"

# 6. Configure & Restart DHCP Helper
# We force it to listen on the cable (eth0) and talk to the air (wlan0)
echo "DHCPHELPER_OPTS=\"-i $ETH_IFACE -b $WIFI_IFACE\"" | sudo tee /etc/default/dhcp-helper > /dev/null
systemctl start dhcp-helper