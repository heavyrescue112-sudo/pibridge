#!/bin/bash

# --- SELF-UPDATER ---
if [ "$1" == "update" ]; then
    echo "Checking GitHub for the latest .deb release..."
    URL=$(curl -s https://api.github.com/repos/heavyrescue112-sudo/PiBridge/releases/latest \
          | grep "browser_download_url" | grep ".deb" | head -n 1 | sed -E 's/.*"([^"]+)".*/\1/')
    if [ -z "$URL" ]; then echo "Error: No .deb found."; exit 1; fi
    curl -L "$URL" -o /tmp/pibridge.deb
    sudo apt install --reinstall -y /tmp/pibridge.deb
    rm /tmp/pibridge.deb
    exit 0
fi

# --- BRIDGE CONFIG ---
WIFI_IFACE="wlan0"
ETH_IFACE="eth0"
# Keeping it in the .68 range to match your Pi's Wi-Fi (.68.82)
ETH_IP="192.168.68.250/22" 

# 1. Force NetworkManager to release the port
nmcli device set "$ETH_IFACE" managed no 2>/dev/null

# 2. Reset and Configure the Physical Port
ip link set "$ETH_IFACE" down
ip addr flush dev "$ETH_IFACE"
ip link set "$ETH_IFACE" up
ip addr add "$ETH_IP" dev "$ETH_IFACE"

# 3. Enable Kernel IP Forwarding
sysctl -w net.ipv4.ip_forward=1 > /dev/null

# 4. Start the Proxy ARP engine (The Bridge)
killall parprouted 2>/dev/null 
sleep 1
parprouted "$WIFI_IFACE" "$ETH_IFACE"

# 5. Configure & Restart the DHCP Helper
# We are forcing it to listen on ETH and relay to WIFI
echo "DHCPHELPER_OPTS=\"-i $ETH_IFACE -b $WIFI_IFACE\"" | sudo tee /etc/default/dhcp-helper > /dev/null
systemctl restart dhcp-helper