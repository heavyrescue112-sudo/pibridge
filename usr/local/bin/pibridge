#!/bin/bash

# --- SELF-UPDATER ---
if [ "$1" == "update" ]; then
    echo "Checking GitHub for the latest .deb release..."
    URL=$(curl -s https://api.github.com/repos/heavyrescue112-sudo/PiBridge/releases/latest \
          | grep "browser_download_url" | grep ".deb" | head -n 1 | sed -E 's/.*"([^"]+)".*/\1/')
    if [ -z "$URL" ]; then echo "Error: No .deb found."; exit 1; fi
    curl -L "$URL" -o /tmp/pibridge.deb
    sudo apt install --reinstall -y /tmp/pibridge.deb
    rm /tmp/pibridge.deb
    exit 0
fi

# --- BRIDGE CONFIG ---
WIFI_IFACE="wlan0"
ETH_IFACE="eth0"
# We use /32 here so it doesn't create a conflicting subnet route
ETH_IP="192.168.68.250/32" 

# 1. Kill old services
systemctl stop dhcp-helper 2>/dev/null
killall parprouted 2>/dev/null 

# 2. Reset Ethernet Port
nmcli device set "$ETH_IFACE" managed no 2>/dev/null
ip link set "$ETH_IFACE" down
ip addr flush dev "$ETH_IFACE"
ip link set "$ETH_IFACE" up
# We manually add the IP as a host-only address
ip addr add "$ETH_IP" dev "$ETH_IFACE"

sleep 2

# 3. Apply Kernel Settings
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv4.conf.all.proxy_arp=1
sysctl -w net.ipv4.conf.$WIFI_IFACE.proxy_arp=1
sysctl -w net.ipv4.conf.$ETH_IFACE.proxy_arp=1

# 4. Promiscuous Mode
ip link set "$WIFI_IFACE" promisc on
ip link set "$ETH_IFACE" promisc on

# 5. Start the Engine
# We'll use the -d flag briefly for better logging if you check journalctl
parprouted "$WIFI_IFACE" "$ETH_IFACE"

# 6. DIRECT RELAY
ROUTER_IP=$(ip route | grep default | awk '{print $3}' | head -n 1)
echo "DHCPHELPER_OPTS=\"-i $ETH_IFACE -s $ROUTER_IP\"" | sudo tee /etc/default/dhcp-helper > /dev/null
systemctl start dhcp-helper